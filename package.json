{
  "name": "marketplace",
  "version": "1.0.0",
  "description": "Full-stack Node.js e-commerce marketplace — Express API + Vue 3 frontend",
  "private": true,
  "scripts": {
    "build": "cd frontend && npm install && npm run build",
    "start": "cd backend && node server.js",
    "dev:backend": "cd backend && node server.js",
    "dev:frontend": "cd frontend && npx vite dev --port 8000"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "dotenv": "^16.0.0",
    "express": "~4.16.1",
    "http-errors": "~1.6.3",
    "jsonwebtoken": "^8.5.1",
    "mongoose": "^6.2.4",
    "morgan": "~1.9.1",
    "multer": "^1.4.4"
  },
  "engines": {
    "node": ">=18.x"
  }
}