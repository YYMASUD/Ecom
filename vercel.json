{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/main/(.*)",    "dest": "/api/index" },
    { "src": "/user/(.*)",    "dest": "/api/index" },
    { "src": "/cart/(.*)",    "dest": "/api/index" },
    { "src": "/order/(.*)",   "dest": "/api/index" },
    { "src": "/seller/(.*)",  "dest": "/api/index" },
    { "src": "/admin/(.*)",   "dest": "/api/index" },
    { "src": "/uploads/(.*)", "dest": "/api/index" },
    { "src": "/health",       "dest": "/api/index" },
    { "src": "/(.*)",         "dest": "/index.html" }
  ]
}